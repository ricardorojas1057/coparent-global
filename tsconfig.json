{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2021"
  },
  "include": ["api/**/*.ts", "apps/backend/src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "node_modules"]
}
