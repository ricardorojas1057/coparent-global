        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "30610428855-ueh3tipa2h3aj508eufk3i4fphhd2qit.apps.googleusercontent.com",
        "EXPO_PUBLIC_WEB_URL": "https://coparent-global.vercel.app"
